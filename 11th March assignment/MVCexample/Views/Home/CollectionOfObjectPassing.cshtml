@model IEnumerable<MVCexample.Models.Employee>
@{
    ViewData["Title"] = "CollectionOfObjectPassing";
}

<h1>CollectionOfObjectPassing</h1>
<style>
	table {
		border-collapse: collapse;
		width: 50%;
	}

	table, th, td {
		border: 2px solid black;
	}

	th, td {
		padding: 8px;
		text-align: left;
	}
</style>

<table>
	<thead>
		<tr>
			<th>EmployeeID</th>
			<th>EmpName</th>
			<th>Salary</th>
			<th>Images</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var emp in Model)
		{
			<tr>
				<td>@emp.EmployeeId</td>
				<td>@emp.EmployeeName</td>
				<td>@emp.EmployeeSalary</td>
				<td><img src="@emp.ImageUrl" alt="Employee Image" width="100" height="100"/></td>
			</tr>
        }
	</tbody>
</table>
